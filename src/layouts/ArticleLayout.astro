---
import BaseLayout from "./BaseLayout.astro";
import { formatDate } from "../lib/content";

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  updatedDate?: Date;
  category?: string;
  tags?: string[];
}

const { title, description, pubDate, updatedDate, category, tags = [] } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="article-shell">
    <header class="article-header">
      <div class="meta">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        {updatedDate && <span>更新于 {formatDate(updatedDate)}</span>}
        {category && <span>{category}</span>}
      </div>
      <h1>{title}</h1>
      {tags.length > 0 && (
        <div class="badge-row" style="margin-top: 18px;">
          {tags.map((tag) => <a class="badge" href={`/blog/?tag=${encodeURIComponent(tag)}`}>{tag}</a>)}
        </div>
      )}
    </header>
    <div class="article-content">
      <slot />
    </div>
  </article>
</BaseLayout>
