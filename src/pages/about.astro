---
import { getCollection } from "astro:content";
import ArticleCard from "../components/ArticleCard.astro";
import Badge from "../components/Badge.astro";
import PageHeader from "../components/PageHeader.astro";
import Section from "../components/Section.astro";
import { channels } from "../data/channels";
import { profile } from "../data/profile";
import BaseLayout from "../layouts/BaseLayout.astro";
import { blogCardDescription, entrySlug, isPublished, sortByDate } from "../lib/content";

const growthTag = "个人成长";
const growthPosts = sortByDate((await getCollection("blog")).filter(isPublished))
  .filter((post) => post.data.tags.includes(growthTag))
  .slice(0, 3);

const growthHref = `/blog/?tag=${encodeURIComponent(growthTag)}`;
const wechatChannel = channels.find((channel) => channel.name === "微信公众号");
---

<BaseLayout title="关于" description={profile.bio}>
  <PageHeader eyebrow="About" title="关于肖恩" description={profile.bio} />
  <div class="shell">
    <Section title="关注方向">
      <div class="badge-row">
        {profile.focus.map((item) => <Badge>{item}</Badge>)}
      </div>
    </Section>

    <Section title="了解我" href={growthHref} linkLabel="查看更多">
      <div class="article-list">
        {growthPosts.map((post) => (
          <ArticleCard
            href={`/blog/${entrySlug(post)}/`}
            title={post.data.title}
            description={blogCardDescription(post)}
            date={post.data.pubDate}
            category={post.data.category}
            tags={post.data.tags}
          />
        ))}
      </div>
    </Section>

    <Section title="更多渠道">
      <div class="channel-grid">
        {channels.map((channel) => (
          channel.name === "微信公众号" ? (
            <button class="channel-card" type="button" data-open-wechat-image>
              <span class="channel-type">{channel.type}</span>
              <strong>{channel.name}</strong>
              <span>{channel.description}</span>
            </button>
          ) : (
            <a class="channel-card" href={channel.url} target="_blank" rel="noreferrer">
              <span class="channel-type">{channel.type}</span>
              <strong>{channel.name}</strong>
              <span>{channel.description}</span>
            </a>
          )
        ))}
      </div>
    </Section>
  </div>

  {wechatChannel && (
    <dialog class="image-dialog" data-image-dialog aria-label="公众号二维码全屏预览">
      <button class="image-dialog-close" type="button" data-close-wechat-image aria-label="关闭全屏预览">×</button>
      <img src={wechatChannel.url} alt="肖恩聊技术公众号二维码全屏预览" loading="lazy" />
    </dialog>
  )}

  <script>
    const imageDialog = document.querySelector("[data-image-dialog]");
    const openWechatImageButtons = document.querySelectorAll("[data-open-wechat-image]");
    const closeWechatImageButton = document.querySelector("[data-close-wechat-image]");

    const openWechatImage = () => {
      if (!(imageDialog instanceof HTMLDialogElement)) return;
      if (typeof imageDialog.showModal === "function") {
        imageDialog.showModal();
      } else {
        imageDialog.setAttribute("open", "");
      }
    };

    const closeWechatImage = () => {
      if (!(imageDialog instanceof HTMLDialogElement)) return;
      imageDialog.close();
    };

    openWechatImageButtons.forEach((button) => button.addEventListener("click", openWechatImage));
    closeWechatImageButton?.addEventListener("click", closeWechatImage);
    imageDialog?.addEventListener("click", (event) => {
      if (event.target === imageDialog) closeWechatImage();
    });
  </script>
</BaseLayout>

<style>
  .channel-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .channel-card {
    display: grid;
    min-width: 0;
    gap: 10px;
    padding: 16px;
    color: inherit;
    text-align: left;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    cursor: pointer;
    transition: background 140ms ease, box-shadow 140ms ease, transform 140ms ease;
  }

  .channel-card:hover {
    color: var(--text);
    background: var(--surface-muted);
    box-shadow: var(--shadow);
    transform: translate(-2px, -2px);
  }

  .channel-card strong {
    font-size: 1.05rem;
    line-height: 1.3;
  }

  .channel-card span:last-child {
    color: var(--muted);
    line-height: 1.65;
  }

  .channel-type {
    color: var(--subtle);
    font-size: 0.82rem;
    text-transform: uppercase;
  }

  .image-dialog-close {
    position: absolute;
    top: 12px;
    right: 12px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    color: var(--text);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    cursor: pointer;
  }

  .image-dialog-close:hover {
    color: var(--surface);
    background: var(--text);
  }

  .image-dialog {
    position: fixed;
    inset: 0;
    width: 100dvw;
    height: 100dvh;
    max-width: none;
    max-height: none;
    margin: 0;
    padding: 24px;
    color: #f7f7f7;
    background: #111111;
    border: 0;
    border-radius: 0;
    cursor: zoom-out;
    overflow: hidden;
  }

  .image-dialog[open] {
    display: grid;
    place-items: center;
  }

  .image-dialog::backdrop {
    background: #111111;
  }

  .image-dialog img {
    display: block;
    width: min(920px, calc(100dvw - 48px));
    max-height: calc(100dvh - 48px);
    border: 0;
    object-fit: contain;
    cursor: zoom-out;
  }

  .image-dialog-close {
    top: 10px;
    right: 10px;
    width: 36px;
    height: 36px;
    color: #f7f7f7;
    background: rgba(0, 0, 0, 0.58);
    border-color: rgba(255, 255, 255, 0.42);
  }

  .image-dialog-close:hover {
    color: #111111;
    background: #ffffff;
  }

  body:has(.image-dialog[open]) {
    overflow: hidden;
  }

  @media (max-width: 760px) {
    .channel-grid {
      grid-template-columns: 1fr;
    }

    .image-dialog {
      padding: 12px;
    }

    .image-dialog img {
      width: min(920px, calc(100dvw - 24px));
      max-height: calc(100dvh - 24px);
    }
  }
</style>
