---
import Badge from "../../components/Badge.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { affDisclosure, affItems } from "../../data/aff";
import { renderMarkdownLinks, stripMarkdownLinks } from "../../lib/markdown";
import { site } from "../../data/profile";

export function getStaticPaths() {
  return affItems.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const plainDescription = stripMarkdownLinks(item.description);
const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: item.name,
  description: plainDescription,
  image: new URL(item.image, site.url).toString(),
  url: new URL(`/aff/${item.slug}/`, site.url).toString(),
  category: item.type,
  brand: {
    "@type": "Brand",
    name: item.name,
  },
  additionalProperty: item.tags.map((tag) => ({
    "@type": "PropertyValue",
    name: "标签",
    value: tag,
  })),
};
---

<BaseLayout title={item.name} description={plainDescription} image={item.image} jsonLd={productJsonLd}>
  <div class="shell">
    <article class="aff-detail">
      <header class="aff-hero">
        <div class="aff-hero-main">
          <p class="eyebrow">{item.type}</p>
          <h1 class="page-title">{item.name}</h1>
          <p class="page-description" set:html={renderMarkdownLinks(item.description)} />
        </div>

        <aside class="aff-aside" aria-label={`${item.name} 跳转信息`}>
          <dl>
            <div>
              <dt>类型</dt>
              <dd>{item.type}</dd>
            </div>
            <div>
              <dt>更新</dt>
              <dd>{item.updatedAt}</dd>
            </div>
          </dl>
          <a class="button-link" href={item.url} target="_blank" rel="noreferrer">跳转访问</a>
        </aside>
      </header>

      <div class="badge-row aff-badges">
        {item.tags.map((tag) => <Badge>{tag}</Badge>)}
      </div>

      <div class="notice">{affDisclosure}</div>

      <figure class="aff-shot">
        <img src={item.image} alt={`${item.name} 截图`} />
      </figure>
    </article>
  </div>
</BaseLayout>

<style>
  .aff-detail {
    display: grid;
    gap: 14px;
    padding: 54px 0 28px;
  }

  .aff-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 300px;
    gap: 18px;
    align-items: start;
  }

  .aff-hero-main {
    display: grid;
    gap: 14px;
    min-width: 0;
  }

  .aff-hero-main .page-description {
    margin-top: 0;
  }

  .aff-hero-main .page-description a {
    color: var(--accent);
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .aff-badges {
    margin-top: -2px;
  }

  .aff-shot {
    margin: 0;
    background: var(--surface);
    border: 1px solid var(--border);
  }

  .aff-shot img {
    display: block;
    width: 100%;
    max-height: 520px;
    object-fit: contain;
    background: var(--surface);
  }

  .aff-aside {
    display: grid;
    gap: 14px;
    min-width: 0;
    position: sticky;
    top: 86px;
    padding: 16px;
    background: var(--surface);
    border: 1px solid var(--border);
  }

  .aff-aside dl {
    display: grid;
    gap: 0;
    margin: 0;
    border: 1px solid var(--border);
  }

  .aff-aside dl div {
    display: grid;
    grid-template-columns: 72px minmax(0, 1fr);
    border-bottom: 1px solid var(--border);
  }

  .aff-aside dl div:last-child {
    border-bottom: 0;
  }

  .aff-aside dt,
  .aff-aside dd {
    margin: 0;
    padding: 9px 10px;
  }

  .aff-aside dt {
    color: var(--subtle);
    border-right: 1px solid var(--border);
    font-size: 0.78rem;
    text-transform: uppercase;
  }

  .aff-aside dd {
    overflow-wrap: anywhere;
    font-weight: 700;
  }

  @media (max-width: 700px) {
    .aff-hero {
      grid-template-columns: 1fr;
    }

    .aff-aside {
      position: static;
    }
  }
</style>
