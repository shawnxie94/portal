---
import PageHeader from "../../components/PageHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { affDisclosure, affItems } from "../../data/aff";
import { renderMarkdownLinks, stripMarkdownLinks } from "../../lib/markdown";
import { site } from "../../data/profile";

const affTypeOrder = ["大模型服务", "机场", "效率", "云服务"];
const affTypes = affTypeOrder.filter((type) => affItems.some((item) => item.type === type));
const affJsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "肖恩的推广推荐",
  description: "按大模型服务、机场、效率、云服务分类整理的推广和订阅推荐。",
  url: new URL("/aff/", site.url).toString(),
  itemListElement: affItems.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    url: new URL(`/aff/${item.slug}/`, site.url).toString(),
    item: {
      "@type": "Product",
      name: item.name,
      description: stripMarkdownLinks(item.description),
      category: item.type,
      image: new URL(item.image, site.url).toString(),
    },
  })),
};
---

<BaseLayout title="推广" description="肖恩整理的推广和订阅推荐，按大模型服务、机场、效率、云服务分类展示产品说明、截图、跳转入口和返利声明。" jsonLd={affJsonLd}>
  <PageHeader eyebrow="Aff" title="推广" description="分享个人长期使用产品，更偏好高性价比。" />
  <div class="shell">
    <section class="section">
      <div class="notice">{affDisclosure}</div>
    </section>

    <div class="aff-groups">
      {affTypes.map((type) => (
        <section class="aff-group" aria-labelledby={`aff-${type}`}>
          <div class="section-head">
            <div class="aff-section-title">
              <h2 id={`aff-${type}`}>{type}</h2>
            </div>
          </div>

          <div class="aff-card-grid">
            {affItems
              .filter((item) => item.type === type)
              .map((item) => (
                <article class="aff-card">
                  <div class="aff-card-body">
                    <h3><a href={`/aff/${item.slug}/`}>{item.name}</a></h3>
                    <p set:html={renderMarkdownLinks(item.description)} />
                    <div class="aff-tags">
                      {item.tags.slice(0, 3).map((tag) => (
                        <span><i aria-hidden="true">#</i><b>{tag}</b></span>
                      ))}
                    </div>
                  </div>
                </article>
              ))}
          </div>
        </section>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .aff-groups {
    display: grid;
    gap: 30px;
    padding-bottom: 28px;
  }

  .aff-group {
    display: grid;
    gap: 14px;
  }

  .aff-section-title {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 10px;
  }

  .aff-card-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .aff-card {
    display: grid;
    min-width: 0;
    color: inherit;
    background: var(--surface);
    border: 1px solid var(--border);
    text-decoration: none;
    transition: background 140ms ease, box-shadow 140ms ease, transform 140ms ease;
  }

  .aff-card:hover {
    background: var(--surface-muted);
    box-shadow: var(--shadow);
    transform: translate(-2px, -2px);
  }

  .aff-card-body {
    display: grid;
    align-content: start;
    gap: 10px;
    padding: 14px;
  }

  .aff-card h3 {
    margin: 0;
    font-size: 1.08rem;
    line-height: 1.35;
  }

  .aff-card h3 a {
    color: inherit;
    text-decoration: none;
  }

  .aff-card h3 a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .aff-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.65;
  }

  .aff-card p a {
    color: var(--accent);
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .aff-tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
  }

  .aff-tags span {
    display: inline-flex;
    align-items: center;
    height: 24px;
    gap: 1px;
    color: var(--subtle);
    font-size: 0.8rem;
    line-height: 24px;
  }

  .aff-tags i,
  .aff-tags b {
    display: inline-flex;
    align-items: center;
    height: 24px;
    font-style: normal;
    font-weight: 640;
    line-height: 1;
  }

  @media (max-width: 940px) {
    .aff-card-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .aff-card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
