---
import { getCollection } from "astro:content";
import ArticleCard from "../components/ArticleCard.astro";
import Badge from "../components/Badge.astro";
import LinkCard from "../components/LinkCard.astro";
import Section from "../components/Section.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { affItems } from "../data/aff";
import { profile, site } from "../data/profile";
import { projects } from "../data/projects.mjs";
import { blogCardDescription, entrySlug, isPublished, sortByDate } from "../lib/content";
import { buildUpdates } from "../lib/updates";

const publishedPosts = (await getCollection("blog")).filter(isPublished);
const posts = sortByDate([...publishedPosts]).slice(0, 3);
const featuredProjects = projects.filter((project) => project.featured).slice(0, 3);
const updates = buildUpdates({ posts: publishedPosts, projects, affItems });
---

<BaseLayout title={site.title} description={site.description}>
  <dialog class="wechat-dialog" id="wechat-qrcode" aria-labelledby="wechat-qrcode-title">
    <div class="wechat-dialog__inner">
      <h2 id="wechat-qrcode-title">微信公众号</h2>
      <p>扫码关注「肖恩聊技术」</p>
      <img src="/images/profile/20241103221454-9f58489a.png" alt="微信公众号二维码" width="220" height="220" />
      <button type="button" class="wechat-dialog__close" data-wechat-close aria-label="关闭">×</button>
    </div>
  </dialog>
  <section class="shell home-hero">
    <div class="hero-main">
      <p class="eyebrow">Personal Portal</p>
      <h1 class="terminal-name" aria-label="肖恩 / Shawn">
        <span class="terminal-name__sizer" aria-hidden="true">Shawn</span>
        <span class="terminal-name__line" aria-hidden="true">
          <span class="terminal-name__text" data-terminal-name>{profile.name}</span><span class="terminal-name__cursor"></span>
        </span>
      </h1>
      <p class="hero-headline">{profile.headline}</p>
      <p>{profile.bio}</p>
      <div class="badge-row">
        {profile.focus.map((item) => <Badge>{item}</Badge>)}
      </div>
      <div class="hero-actions">
        <a class="button-link" href="/blog/">阅读文章</a>
        <a class="button-link secondary" href="/projects/">查看项目</a>
        <a class="button-link secondary" href="/about/">关于我</a>
        <div class="hero-socials" aria-label="其他渠道">
          <button type="button" class="hero-social-trigger" aria-haspopup="dialog" aria-controls="wechat-qrcode" data-wechat-trigger>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8.5 4C4.36 4 1 6.69 1 10c0 1.85 1.05 3.5 2.7 4.6L3 17l2.8-1.5c.6.2 1.3.3 2 .3.2 0 .4 0 .6-.02A6.2 6.2 0 0 1 8 14c0-3.31 3.13-6 7-6 .2 0 .4 0 .6.02C15.18 5.66 12.13 4 8.5 4Zm-2.7 4.5a.9.9 0 1 1 0 1.8.9.9 0 0 1 0-1.8Zm5.4 0a.9.9 0 1 1 0 1.8.9.9 0 0 1 0-1.8ZM15 9c-3.31 0-6 2.24-6 5s2.69 5 6 5c.6 0 1.2-.08 1.75-.23L19 20l-.55-1.95A4.78 4.78 0 0 0 21 14c0-2.76-2.69-5-6-5Zm-2 3.7a.75.75 0 1 1 0 1.5.75.75 0 0 1 0-1.5Zm4 0a.75.75 0 1 1 0 1.5.75.75 0 0 1 0-1.5Z"/></svg>
            <span class="visually-hidden">微信公众号</span>
          </button>
          <a href="https://github.com/shawnxie94" aria-label="GitHub" target="_blank" rel="noreferrer">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.18-3.37-1.18-.45-1.15-1.11-1.46-1.11-1.46-.91-.62.07-.61.07-.61 1 .07 1.53 1.04 1.53 1.04.9 1.52 2.34 1.08 2.91.82.09-.65.35-1.08.63-1.33-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02A9.55 9.55 0 0 1 12 6.01c.85 0 1.7.11 2.5.34 1.9-1.29 2.74-1.02 2.74-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.68-4.57 4.93.36.31.68.92.68 1.86v2.76c0 .27.18.58.69.48A10 10 0 0 0 12 2Z"/></svg>
          </a>
          <a href="https://x.com/ShawnXTalk" aria-label="X" target="_blank" rel="noreferrer">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M13.62 10.63 20.03 3h-1.52l-5.56 6.62L8.5 3H3.38l6.72 10-6.72 8h1.52l5.88-7 4.7 7h5.13l-6.99-10.37Zm-2.08 2.48-.68-.98-5.42-7.94h2.33l4.37 6.4.68.98 5.69 8.34h-2.33l-4.64-6.8Z"/></svg>
          </a>
          <a href="/rss.xml" aria-label="RSS">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5.6 17.2a1.8 1.8 0 1 1 0 3.6 1.8 1.8 0 0 1 0-3.6ZM3.8 9.6c5.85 0 10.6 4.75 10.6 10.6h-2.55a8.05 8.05 0 0 0-8.05-8.05V9.6Zm0-6.4c9.39 0 17 7.61 17 17h-2.55c0-7.98-6.47-14.45-14.45-14.45V3.2Z"/></svg>
          </a>
        </div>
      </div>
    </div>
    <aside class="hero-panel" aria-label="最新动态">
      <h2><a href="/now/">最新动态</a></h2>
      <div class="timeline-list">
        {updates.slice(0, 4).map((item) => (
          <a href={item.url}>
            <span class="timeline-meta">
              <time datetime={item.date}>{item.date}</time>
              <span>{item.type}</span>
            </span>
            <strong>{item.title}</strong>
          </a>
        ))}
      </div>
    </aside>
  </section>

  <div class="shell">
    <Section title="个人项目" href="/projects/">
      <div class="grid three">
        {featuredProjects.map((project) => (
          <LinkCard href={project.url} title={project.name} description={project.description} meta={project.tags.join(" / ")} showLinkType={false} />
        ))}
      </div>
    </Section>

    <Section title="最新文章" href="/blog/">
      <div class="article-list">
        {posts.map((post) => (
          <ArticleCard
            href={`/blog/${entrySlug(post)}/`}
            title={post.data.title}
            description={blogCardDescription(post)}
            date={post.data.pubDate}
            category={post.data.category}
          />
        ))}
      </div>
    </Section>
  </div>
</BaseLayout>

<script>
  const terminalName = document.querySelector("[data-terminal-name]");

  if (terminalName instanceof HTMLElement) {
    const words = ["肖恩", "Shawn"];
    const typeDelay = 280;
    const deleteDelay = 150;
    const holdDelay = 1400;
    let wordIndex = 0;
    let characterIndex = words[wordIndex].length;
    let isDeleting = true;

    const writeName = () => {
      const word = words[wordIndex];
      terminalName.textContent = word.slice(0, characterIndex);

      if (!isDeleting && characterIndex === word.length) {
        isDeleting = true;
        window.setTimeout(writeName, holdDelay);
        return;
      }

      if (isDeleting && characterIndex === 0) {
        isDeleting = false;
        wordIndex = (wordIndex + 1) % words.length;
        window.setTimeout(writeName, typeDelay);
        return;
      }

      characterIndex += isDeleting ? -1 : 1;
      window.setTimeout(writeName, isDeleting ? deleteDelay : typeDelay);
    };

    window.setTimeout(writeName, holdDelay);
  }

  const wechatTrigger = document.querySelector("[data-wechat-trigger]");
  const wechatDialog = document.getElementById("wechat-qrcode");
  if (wechatTrigger instanceof HTMLElement && wechatDialog instanceof HTMLDialogElement) {
    wechatTrigger.addEventListener("click", () => {
      if (typeof wechatDialog.showModal === "function") {
        wechatDialog.showModal();
      } else {
        wechatDialog.setAttribute("open", "");
      }
    });
    wechatDialog.addEventListener("click", (event) => {
      if (event.target === wechatDialog || (event.target instanceof HTMLElement && event.target.dataset.wechatClose !== undefined)) {
        wechatDialog.close();
      }
    });
    wechatDialog.querySelector("[data-wechat-close]")?.addEventListener("click", () => wechatDialog.close());
  }
</script>

<style>
  .home-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.65fr);
    gap: 28px;
    padding: 58px 0 30px;
  }

  .hero-main {
    padding-top: 24px;
  }

  .hero-main h1 {
    margin: 0;
    font-size: clamp(3.2rem, 10vw, 7.2rem);
    line-height: 0.95;
    letter-spacing: 0;
    text-shadow: 2px 0 0 rgba(0, 0, 0, 0.16), -2px 0 0 rgba(0, 0, 0, 0.08);
  }

  .terminal-name {
    position: relative;
    display: inline-flex;
    align-items: baseline;
    white-space: nowrap;
  }

  .terminal-name__sizer {
    visibility: hidden;
  }

  .terminal-name__line {
    position: absolute;
    inset: 0 auto auto 0;
    display: inline-flex;
    align-items: baseline;
  }

  .terminal-name__text {
    display: inline-block;
    min-width: 0;
    text-transform: none;
  }

  .terminal-name__cursor {
    display: inline-block;
    width: 0.12em;
    height: 0.78em;
    margin-left: 0.08em;
    background: currentColor;
    transform: translateY(0.06em);
    animation: terminal-cursor-blink 1s steps(1, end) infinite;
  }

  @keyframes terminal-cursor-blink {
    0%,
    48% {
      opacity: 1;
    }

    49%,
    100% {
      opacity: 0;
    }
  }

  .hero-main p {
    max-width: 700px;
    color: var(--muted);
    font-size: 1.08rem;
    line-height: 1.85;
  }

  .hero-main .hero-headline {
    margin: 22px 0 0;
    color: var(--text);
    font-size: 1.32rem;
    font-weight: 680;
  }

  .hero-main .hero-headline::before {
    content: "$ ";
    color: var(--subtle);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    margin-top: 22px;
  }

  .hero-socials {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-left: 4px;
    padding-left: 10px;
    border-left: 1px solid var(--border);
  }

  .hero-socials a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    color: var(--muted);
    background: transparent;
    border: 0;
    text-decoration: none;
    transition: color 140ms ease, transform 140ms ease;
  }

  .hero-socials a:hover {
    color: var(--text);
    transform: translateY(-1px);
  }

  .hero-socials svg {
    width: 16px;
    height: 16px;
    fill: currentColor;
  }

  .hero-socials .hero-social-trigger {
    font: inherit;
    cursor: pointer;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .wechat-dialog {
    padding: 0;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
  }

  .wechat-dialog::backdrop {
    background: rgba(0, 0, 0, 0.55);
  }

  .wechat-dialog__inner {
    position: relative;
    display: grid;
    justify-items: center;
    gap: 10px;
    padding: 22px 28px 24px;
  }

  .wechat-dialog__inner h2 {
    margin: 0;
    font-size: 1.05rem;
  }

  .wechat-dialog__inner p {
    margin: 0;
    color: var(--muted);
    font-size: 0.92rem;
  }

  .wechat-dialog__inner img {
    display: block;
    width: 220px;
    height: 220px;
    background: #fff;
    padding: 8px;
    border: 1px solid var(--border);
  }

  .wechat-dialog__close {
    position: absolute;
    top: 6px;
    right: 8px;
    width: 28px;
    height: 28px;
    padding: 0;
    color: var(--muted);
    background: transparent;
    border: 0;
    font-size: 1.4rem;
    line-height: 1;
    cursor: pointer;
  }

  .wechat-dialog__close:hover {
    color: var(--text);
  }

  .hero-panel {
    align-self: start;
    padding: 20px;
    background:
      linear-gradient(rgba(0, 0, 0, 0.035) 1px, transparent 1px),
      var(--surface);
    background-size: 100% 9px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .hero-panel h2 {
    margin: 0 0 14px;
    font-size: 1.1rem;
    text-transform: uppercase;
  }

  .hero-panel h2 a {
    color: inherit;
    text-decoration: none;
  }

  .hero-panel h2 a:hover {
    text-decoration: underline;
    text-decoration-thickness: 1px;
  }

  .hero-panel h2::before {
    content: "tail -f ";
    color: var(--subtle);
  }

  .timeline-list {
    display: grid;
    gap: 14px;
  }

  .timeline-list a {
    display: grid;
    gap: 5px;
    padding-left: 12px;
    border-left: 1px solid var(--border);
    text-decoration: none;
    min-width: 0;
    max-width: 100%;
  }

  .timeline-list a:hover {
    border-left-color: var(--accent);
    transform: translateX(3px);
  }

  .timeline-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    color: var(--subtle);
    font-size: 0.82rem;
  }

  .timeline-meta span {
    padding: 1px 5px;
    color: var(--text);
    border: 1px solid var(--border);
    font-size: 0.72rem;
    line-height: 1.35;
    text-transform: uppercase;
  }

  .timeline-list time {
    color: var(--subtle);
  }

  .timeline-list strong {
    min-width: 0;
    overflow-wrap: anywhere;
    word-break: break-word;
    line-height: 1.45;
  }

  @media (max-width: 860px) {
    .home-hero {
      grid-template-columns: 1fr;
      padding-top: 34px;
    }
  }
</style>
