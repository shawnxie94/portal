---
import { getCollection } from "astro:content";
import ArticleCard from "../components/ArticleCard.astro";
import Badge from "../components/Badge.astro";
import LinkCard from "../components/LinkCard.astro";
import Section from "../components/Section.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { profile, site } from "../data/profile";
import { projects } from "../data/projects";
import { blogCardDescription, entrySlug, isPublished, sortByDate } from "../lib/content";
import { buildUpdates } from "../lib/updates";

const publishedPosts = (await getCollection("blog")).filter(isPublished);
const posts = sortByDate([...publishedPosts]).slice(0, 3);
const featuredProjects = projects.filter((project) => project.featured).slice(0, 3);
const updates = buildUpdates(publishedPosts);
---

<BaseLayout title={site.title} description={site.description}>
  <section class="shell home-hero">
    <div class="hero-main">
      <p class="eyebrow">Personal Portal</p>
      <h1>{profile.name}</h1>
      <p class="hero-headline">{profile.headline}</p>
      <p>{profile.bio}</p>
      <div class="badge-row">
        {profile.focus.map((item) => <Badge>{item}</Badge>)}
      </div>
      <div class="hero-actions">
        <a class="button-link" href="/blog/">阅读文章</a>
        <a class="button-link secondary" href="/projects/">查看项目</a>
        <a class="button-link secondary" href="/about/">关于我</a>
      </div>
    </div>
    <aside class="hero-panel" aria-label="最新动态">
      <h2><a href="/now/">最新动态</a></h2>
      <div class="timeline-list">
        {updates.slice(0, 4).map((item) => (
          <a href={item.url}>
            <time datetime={item.date}>{item.date}</time>
            <strong>{item.title}</strong>
          </a>
        ))}
      </div>
    </aside>
  </section>

  <div class="shell">
    <Section title="个人项目" href="/projects/">
      <div class="grid three">
        {featuredProjects.map((project) => (
          <LinkCard href={project.url} title={project.name} description={project.description} meta={project.tags.join(" / ")} />
        ))}
      </div>
    </Section>

    <Section title="最新文章" href="/blog/">
      <div class="article-list">
        {posts.map((post) => (
          <ArticleCard
            href={`/blog/${entrySlug(post)}/`}
            title={post.data.title}
            description={blogCardDescription(post)}
            date={post.data.pubDate}
            category={post.data.category}
          />
        ))}
      </div>
    </Section>
  </div>
</BaseLayout>

<style>
  .home-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.65fr);
    gap: 28px;
    padding: 58px 0 30px;
  }

  .hero-main {
    padding-top: 24px;
  }

  .hero-main h1 {
    margin: 0;
    font-size: clamp(3.2rem, 10vw, 7.2rem);
    line-height: 0.95;
    letter-spacing: 0;
    text-transform: uppercase;
    text-shadow: 2px 0 0 rgba(0, 0, 0, 0.16), -2px 0 0 rgba(0, 0, 0, 0.08);
  }

  .hero-main p {
    max-width: 700px;
    color: var(--muted);
    font-size: 1.08rem;
    line-height: 1.85;
  }

  .hero-main .hero-headline {
    margin: 22px 0 0;
    color: var(--text);
    font-size: 1.32rem;
    font-weight: 680;
  }

  .hero-main .hero-headline::before {
    content: "$ ";
    color: var(--subtle);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 22px;
  }

  .hero-panel {
    align-self: start;
    padding: 20px;
    background:
      linear-gradient(rgba(0, 0, 0, 0.035) 1px, transparent 1px),
      var(--surface);
    background-size: 100% 9px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .hero-panel h2 {
    margin: 0 0 14px;
    font-size: 1.1rem;
    text-transform: uppercase;
  }

  .hero-panel h2 a {
    color: inherit;
    text-decoration: none;
  }

  .hero-panel h2 a:hover {
    text-decoration: underline;
    text-decoration-thickness: 1px;
  }

  .hero-panel h2::before {
    content: "tail -f ";
    color: var(--subtle);
  }

  .timeline-list {
    display: grid;
    gap: 14px;
  }

  .timeline-list a {
    display: grid;
    gap: 5px;
    padding-left: 12px;
    border-left: 1px solid var(--border);
    text-decoration: none;
    min-width: 0;
    max-width: 100%;
  }

  .timeline-list a:hover {
    border-left-color: var(--accent);
    transform: translateX(3px);
  }

  .timeline-list time {
    color: var(--subtle);
    font-size: 0.82rem;
  }

  .timeline-list strong {
    min-width: 0;
    overflow-wrap: anywhere;
    word-break: break-word;
    line-height: 1.45;
  }

  @media (max-width: 860px) {
    .home-hero {
      grid-template-columns: 1fr;
      padding-top: 34px;
    }
  }
</style>
