---
import { getCollection } from "astro:content";
import PageHeader from "../components/PageHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { affItems } from "../data/aff";
import { projects } from "../data/projects.mjs";
import { buildUpdates } from "../lib/updates";

const pageSize = 10;
const updates = buildUpdates({ posts: await getCollection("blog"), projects, affItems });
---

<BaseLayout title="最新动态" description="看看最近又更新了啥。">
  <PageHeader eyebrow="Now" title="最新动态" description="看看最近又更新了啥。" />
  <div class="shell">
    <section class="section" data-page-size={pageSize}>
      <div class="timeline-page">
        {updates.map((item) => (
          <article class="card timeline-item" data-timeline-item>
            <div class="meta">
              <time datetime={item.date}>{item.date}</time>
              <span>{item.type}</span>
            </div>
            <h2>{item.title}</h2>
            <p>{item.description}</p>
            <a class="button-link secondary" href={item.url}>查看详情</a>
          </article>
        ))}
      </div>
      <nav class="pagination" data-pagination hidden aria-label="最新动态分页">
        <button class="pagination-button" type="button" data-page-prev>上一页</button>
        <div class="pagination-pages" data-page-list></div>
        <button class="pagination-button" type="button" data-page-next>下一页</button>
      </nav>
    </section>
  </div>
</BaseLayout>

<style>
  .timeline-page {
    display: grid;
    gap: 14px;
  }

  .timeline-item {
    overflow: hidden;
  }

  .timeline-item h2 {
    margin: 0;
    overflow-wrap: anywhere;
    font-size: 1.08rem;
    line-height: 1.42;
  }

  .timeline-item .button-link {
    align-self: flex-start;
  }
</style>

<script>
  const timelineItems = [...document.querySelectorAll("[data-timeline-item]")];
  const pageSizeNode = document.querySelector("[data-page-size]");
  const paginationNode = document.querySelector("[data-pagination]");
  const pageListNode = document.querySelector("[data-page-list]");
  const prevButton = document.querySelector("[data-page-prev]");
  const nextButton = document.querySelector("[data-page-next]");
  const pageSize = Number(pageSizeNode?.getAttribute("data-page-size")) || 10;

  const getCurrentPage = () => {
    const params = new URLSearchParams(window.location.search);
    const page = Number(params.get("page") ?? "1");
    return Number.isFinite(page) && page > 0 ? Math.floor(page) : 1;
  };

  const writePage = (page, options = {}) => {
    const params = new URLSearchParams(window.location.search);
    if (page > 1) {
      params.set("page", String(page));
    } else {
      params.delete("page");
    }
    const query = params.toString();
    window.history.replaceState({}, "", `${window.location.pathname}${query ? `?${query}` : ""}`);
    applyPagination();
    if (options.scrollToTop) {
      window.scrollTo({ top: 0, behavior: "smooth" });
    }
  };

  const renderPagination = (currentPage, pageCount) => {
    if (!paginationNode || !pageListNode || !prevButton || !nextButton) return;
    paginationNode.hidden = pageCount <= 1;
    pageListNode.replaceChildren();

    prevButton.disabled = currentPage <= 1;
    nextButton.disabled = currentPage >= pageCount;
    prevButton.onclick = () => writePage(Math.max(1, currentPage - 1), { scrollToTop: true });
    nextButton.onclick = () => writePage(Math.min(pageCount, currentPage + 1), { scrollToTop: true });

    for (let page = 1; page <= pageCount; page += 1) {
      const button = document.createElement("button");
      button.className = "pagination-button";
      button.type = "button";
      button.textContent = String(page);
      button.setAttribute("aria-current", page === currentPage ? "page" : "false");
      button.addEventListener("click", () => writePage(page, { scrollToTop: true }));
      pageListNode.append(button);
    }
  };

  function applyPagination() {
    const pageCount = Math.max(1, Math.ceil(timelineItems.length / pageSize));
    const page = getCurrentPage();
    const currentPage = Math.min(page, pageCount);
    if (currentPage !== page) {
      writePage(currentPage);
      return;
    }

    timelineItems.forEach((item) => {
      item.hidden = true;
    });
    timelineItems.slice((currentPage - 1) * pageSize, currentPage * pageSize).forEach((item) => {
      item.hidden = false;
    });
    renderPagination(currentPage, pageCount);
  }

  window.addEventListener("popstate", applyPagination);
  applyPagination();
</script>
