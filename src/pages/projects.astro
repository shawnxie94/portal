---
import PageHeader from "../components/PageHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import githubStats from "../data/github-stats.json";
import { site } from "../data/profile";
import { projects } from "../data/projects.mjs";

const projectsWithStats = projects.map((project) => ({
  ...project,
  stats: githubStats.repos[project.github] ?? project.stats,
}));
const projectsJsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "肖恩的应用项目",
  description: "肖恩持续构建的应用项目、开源项目和产品介绍。",
  url: new URL("/projects/", site.url).toString(),
  itemListElement: projectsWithStats.map((project, index) => ({
    "@type": "ListItem",
    position: index + 1,
    url: new URL(`/projects/#${project.slug}`, site.url).toString(),
    item: {
      "@type": "SoftwareApplication",
      name: project.name,
      description: project.description,
      url: project.url,
      codeRepository: project.repo,
      programmingLanguage: project.stats.language,
      applicationCategory: "DeveloperApplication",
      keywords: project.tags.join(", "),
    },
  })),
};
---

<BaseLayout title="项目" description="肖恩持续构建的应用项目、开源项目和产品入口，包含 Lumina、Infinitum、Readrops Lumina 等项目的能力说明、源码和产品介绍。" jsonLd={projectsJsonLd}>
  <PageHeader eyebrow="Projects" title="项目" description="持续构建，意义自然浮现。" />
  <div class="shell">
    <section class="project-list" aria-label="应用项目">
      {projectsWithStats.map((project) => (
        <article class="project-row" id={project.slug}>
          <div class="project-main">
            <div class="project-title-row">
              <h2>{project.name}</h2>
              <span>{project.status}</span>
            </div>
            <p>{project.description}</p>
            <div class="project-tags" aria-label={`${project.name} 标签`}>
              {project.tags.map((tag) => (
                <span><i aria-hidden="true">#</i><b>{tag}</b></span>
              ))}
            </div>
          </div>

          <div class="project-side">
            <dl class="project-stats" aria-label={`${project.name} 项目数据`}>
              <div>
                <dt>Stars</dt>
                <dd>{project.stats.stars}</dd>
              </div>
              <div>
                <dt>Lang</dt>
                <dd>{project.stats.language}</dd>
              </div>
            </dl>
            <div class="project-actions">
              {project.articleUrl && <a class="button-link" href={project.articleUrl}>产品介绍</a>}
              {project.url !== project.repo && (
                <a class:list={["button-link", project.urlLabel !== "下载安装" && "secondary"]} href={project.url}>
                  {project.urlLabel ?? "访问站点"}
                </a>
              )}
              <a class="button-link secondary" href={project.repo}>GitHub</a>
            </div>
          </div>
        </article>
      ))}
    </section>
  </div>
</BaseLayout>

<style>
  .project-list {
    display: grid;
    gap: 12px;
    padding: 12px 0 28px;
  }

  .project-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.44fr);
    gap: 18px;
    padding: 18px;
    border: 1px solid var(--border);
    background: var(--surface);
  }

  .project-main {
    display: grid;
    gap: 10px;
    min-width: 0;
  }

  .project-title-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
    min-width: 0;
  }

  .project-title-row h2 {
    margin: 0;
    font-size: 1.35rem;
    line-height: 1.25;
  }

  .project-title-row span {
    color: var(--subtle);
    font-size: 0.82rem;
    text-transform: uppercase;
  }

  .project-main p {
    max-width: 720px;
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
  }

  .project-tags span {
    display: inline-flex;
    align-items: center;
    height: 24px;
    gap: 1px;
    color: var(--muted);
    font-size: 0.82rem;
    line-height: 24px;
  }

  .project-tags i,
  .project-tags b {
    display: inline-flex;
    align-items: center;
    height: 24px;
    font-style: normal;
    font-weight: 640;
    line-height: 1;
  }

  .project-side {
    display: grid;
    align-content: start;
    justify-items: end;
    gap: 12px;
  }

  .project-stats {
    display: grid;
    width: fit-content;
    grid-template-columns: repeat(2, minmax(118px, 118px));
    gap: 0;
    margin: 0;
    border: 1px solid var(--border);
  }

  .project-stats div {
    min-width: 0;
    padding: 9px 10px;
    border-right: 1px solid var(--border);
  }

  .project-stats div:last-child {
    border-right: 0;
  }

  .project-stats dt {
    color: var(--subtle);
    font-size: 0.72rem;
    text-transform: uppercase;
  }

  .project-stats dd {
    margin: 3px 0 0;
    overflow-wrap: anywhere;
    font-weight: 760;
    line-height: 1.2;
  }

  .project-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    width: min(100%, 324px);
    gap: 10px;
  }

  @media (max-width: 760px) {
    .project-row {
      grid-template-columns: 1fr;
    }

    .project-side,
    .project-actions {
      justify-items: stretch;
      justify-content: flex-start;
    }

    .project-stats,
    .project-actions {
      width: 100%;
    }
  }

  @media (max-width: 360px) {
    .project-stats {
      grid-template-columns: 1fr;
    }

    .project-stats div {
      border-right: 0;
      border-bottom: 1px solid var(--border);
    }

    .project-stats div:last-child {
      border-bottom: 0;
    }
  }
</style>
