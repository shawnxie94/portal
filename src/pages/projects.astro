---
import Badge from "../components/Badge.astro";
import LinkCard from "../components/LinkCard.astro";
import PageHeader from "../components/PageHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects } from "../data/projects";
---

<BaseLayout title="项目" description="个人项目、开源项目、产品入口和内容项目。">
  <PageHeader eyebrow="Projects" title="项目与产品" description="个人项目、开源项目、产品入口和内容项目。每个卡片保留状态、链接和标签。" />
  <div class="shell">
    <section class="section grid two">
      {projects.map((project) => (
        <article class="card">
          <div class="meta">
            <span>{project.status}</span>
            {project.featured && <Badge>featured</Badge>}
          </div>
          <h2>{project.name}</h2>
          <p>{project.description}</p>
          <div class="badge-row">
            {project.tags.map((tag) => <Badge>{tag}</Badge>)}
          </div>
          <div class="hero-actions">
            <a class="button-link secondary" href={project.url}>访问项目</a>
            {"repo" in project && project.repo && <a class="button-link secondary" href={project.repo}>源码</a>}
          </div>
        </article>
      ))}
    </section>
  </div>
</BaseLayout>

<style>
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: auto;
  }
</style>
