---
import Badge from "../../components/Badge.astro";
import LinkCard from "../../components/LinkCard.astro";
import PageHeader from "../../components/PageHeader.astro";
import Section from "../../components/Section.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { tools } from "../../data/tools";

const groups = new Map<string, typeof tools>();
for (const tool of tools) {
  const group = groups.get(tool.category) ?? [];
  group.push(tool);
  groups.set(tool.category, group);
}
---

<BaseLayout title="工具" description="肖恩聊技术的轻量工具集合，规划 JSON、Base64、URL、时间戳、图片和 PDF 等本地优先的效率工具。">
  <PageHeader eyebrow="Tools" title="工具集合" description="首期先提供工具分类、状态标识和独立工具页框架。具体交互工具后续按需加载，不影响首页和博客性能。" />
  <div class="shell">
    {[...groups.entries()].map(([category, items]) => (
      <Section title={category}>
        <div class="grid three">
          {items.map((tool) => (
            <LinkCard href={tool.path} title={tool.name} description={tool.description} meta={`${tool.priority} / ${tool.status}`} external={false} />
          ))}
        </div>
      </Section>
    ))}
    <section class="section">
      <div class="notice">文件类工具默认规划为浏览器本地处理，不上传文件；大型依赖只会进入对应工具页 chunk。</div>
    </section>
  </div>
</BaseLayout>
